# API Gateway Security Settings
JWT_SECRET_KEY=super-secret-key-change-in-production-123456
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Default access credentials
API_USERNAME=admin
API_PASSWORD=admin123

# Cloud Storage / Local MinIO Configuration
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=mlops-bucket
# Set S3_ENDPOINT_URL for local MinIO testing. Leave commented out in production for real AWS S3.
S3_ENDPOINT_URL=http://localhost:9000

# Drift & Performance Alert Thresholds
DRIFT_THRESHOLD_PSI=0.25
DRIFT_THRESHOLD_KS=0.05
PERFORMANCE_THRESHOLD_F1=0.80

# AutoML Settings
OPTUNA_TRIALS=5
LOCAL_STORAGE_DIR=./data_store
